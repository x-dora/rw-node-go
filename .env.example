# Main rw-node-go runtime configuration.
# Copy this file to .env for local runs. .env is intentionally ignored by git.

# Panel-facing API port.
NODE_PORT=2222

# Local-only internal REST API port. Do not expose this port publicly.
INTERNAL_REST_PORT=61001

# SECRET_KEY generated by the Panel for this node. Leave empty for local HTTP
# development; set REQUIRE_SECRET_KEY=true in production-like runs.
SECRET_KEY=
REQUIRE_SECRET_KEY=false

# TLS client certificate auth for the Panel-facing API when SECRET_KEY is set:
# mtls requires and verifies a client certificate; optional verifies one if
# provided; none keeps HTTPS/JWT but does not require a client certificate.
NODE_TLS_CLIENT_AUTH=mtls

# Runtime paths and logging.
RW_NODE_DIR=/opt/rw-node-go
LOG_LEVEL=info
LOG_COLOR=always
REQUEST_BODY_LIMIT_BYTES=1073741824

# Xray geo assets directory used by the main service. Docker images set this
# to /usr/local/share/xray. The live Panel harness uses XRAY_ASSET_DIR in
# .env.integration.local and converts it to XRAY_LOCATION_ASSET when starting.
XRAY_LOCATION_ASSET=
