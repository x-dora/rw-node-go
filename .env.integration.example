# Live Panel integration harness configuration.
# Copy this file to .env.integration.local and fill real values there.
# .env.integration.local is intentionally ignored by git.

# Remnawave Panel base URL, without a trailing slash.
PANEL_BASE_URL=https://panel.example.com

# Panel API key used only by the live integration harness.
PANEL_API_KEY=

# Panel node UUID. run/enable/disable require a full UUID because they modify
# real Panel node state. Only the read-only node command accepts a unique
# UUID/name/address fragment for troubleshooting.
PANEL_NODE_ID=

# Smoke endpoint relative to PANEL_BASE_URL. Use a stable JSON API endpoint.
PANEL_SMOKE_PATH=/api/system/metadata

# SECRET_KEY generated by the Panel for this rw-node-go instance.
SECRET_KEY=

# Local rw-node-go ports.
NODE_PORT=2222
INTERNAL_REST_PORT=61001

# Local runtime settings for scripts/panel-integration.sh.
# The script loads .env.integration.local and calls the internal Go harness.
LOG_LEVEL=info
PANEL_INTEGRATION_LOG_DIR=logs/panel-integration

# Xray geo assets for embedded xray-core. Put geoip.dat and geosite.dat here.
# Docker images use /usr/local/share/xray and set XRAY_LOCATION_ASSET accordingly.
XRAY_ASSET_DIR=runtime/xray
